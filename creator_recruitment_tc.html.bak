<script>
// Language switcher with scroll position preservation
document.querySelectorAll('.lang-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const targetUrl = this.getAttribute('href');
    const currentScroll = window.pageYOffset;
    const slideHeight = window.innerHeight;
    const currentSlide = Math.round(currentScroll / slideHeight);

    // Store scroll position
    sessionStorage.setItem('slidePosition', currentSlide);

    // Navigate to target page
    window.location.href = targetUrl;
  });
});

// Restore scroll position on load
window.addEventListener('load', function() {
  const savedSlide = sessionStorage.getItem('slidePosition');
  if (savedSlide !== null) {
    const slideHeight = window.innerHeight;
    window.scrollTo({
      top: parseInt(savedSlide) * slideHeight,
      behavior: 'instant'
    });
    sessionStorage.removeItem('slidePosition');
  }
});
</script>

</body>
